<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Tdg5StandardConventionsStylecopJsonPath>$(MSBuildThisFileDirectory)../stylecop.json</Tdg5StandardConventionsStylecopJsonPath>
  </PropertyGroup>
  <ItemGroup>
    <AdditionalFiles Include="$(Tdg5StandardConventionsStylecopJsonPath)" Link="stylecop.json" />
  </ItemGroup>
  <Choose>
    <When Condition="'$(GlobalAnalyzerConfigFileOverride)' == ''">
      <ItemGroup>
        <GlobalAnalyzerConfigFiles Include="$(MSBuildThisFileDirectory)../Tdg5.StandardConventions.globalconfig" />
      </ItemGroup>
    </When>
    <Otherwise>
      <ItemGroup>
        <GlobalAnalyzerConfigFiles Include="$(GlobalAnalyzerConfigFileOverride)" />
      </ItemGroup>
    </Otherwise>
  </Choose>
</Project>
